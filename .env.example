# Copy to .env and adjust as needed.
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics
POSTGRES_DB=analytics
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Auth — change this to a long random string for any real deployment.
JWT_SECRET=dev-secret-change-me

# NL-to-SQL assistant (Google Gemini). Required for /nl-query unless LLM_PROVIDER=echo.
GEMINI_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
